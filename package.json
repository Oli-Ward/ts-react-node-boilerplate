{
    "name": "ts-react-node-boilerplate",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm -r --parallel --stream dev",
        "build": "pnpm -r build",
        "lint": "pnpm -r lint",
        "lint:fix": "pnpm -r lint:fix",
        "format": "prettier --ignore-path .gitignore --write '**/*.+(js|ts|json|md)'",
        "format:check": "prettier --ignore-path .gitignore --check '**/*.+(js|ts|json|md)'",
        "test": "pnpm -r test"
    },
    "devDependencies": {
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "prettier": "^3.8.1"
    }
}