# ----------------------------
# Node.js / Dependencies
# ----------------------------
# Ignore all node_modules folders 
node_modules/
**/node_modules/

# ----------------------------
# Environment / Secrets
# ----------------------------
# Local environment variables
.env
.env.local
**/.env

# ----------------------------
# Build outputs
# ----------------------------
dist/
build/
**/dist/
**/build/

# TypeScript incremental compilation files
*.tsbuildinfo
**/*.tsbuildinfo

# Vite build cache
.vite
.vite/

# ----------------------------
# Databases / Storage
# ----------------------------
# Local SQLite or database files
*.db
*.sqlite

# ----------------------------
# Logs
# ----------------------------
*.log
npm-debug.log*
pnpm-debug.log*

# ----------------------------
# Operating system files
# ----------------------------
.DS_Store   # macOS
**/.DS_Store
Thumbs.db   # Windows

# ----------------------------
# IDE / Editor configs
# ----------------------------
.vscode/
.idea/

# ----------------------------
# Lockfiles
# ----------------------------
# Using pnpm; ignore npm lockfiles to avoid conflicts
package-lock.json
**/package-lock.json

# ----------------------------
# Optional / Extras
# ----------------------------
# Uncomment if using coverage or temporary test outputs
# coverage/
# temp/